# /schedule is now a real booking page (schedule/index.html) with the
# calendar embedded — no more 301 to Google Calendar.

# ───────────────── Security headers ─────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set X-Permitted-Cross-Domain-Policies "none"
  Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"
  # Static site: inline scripts/styles are part of the pages, so
  # 'unsafe-inline' is required; everything else is locked down.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://s3.tradingview.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; frame-src https://calendar.google.com https://*.google.com https://www.tradingview-widget.com https://s.tradingview.com https://www.youtube-nocookie.com https://www.youtube.com; connect-src 'self' https://api.gdeltproject.org; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'"
</IfModule>

# ───────────────── Hide sensitive files ─────────────────
# Dotfiles (.htaccess, .git, .DS_Store…) and repo metadata return 404.
# .well-known stays reachable for certificate validation.
<IfModule mod_alias.c>
  RedirectMatch 404 ^/\.(?!well-known)
  RedirectMatch 404 ^/(package-lock\.json|README\.md)$
</IfModule>
# If the host ever enables directory listings, keep them empty.
<IfModule mod_autoindex.c>
  IndexIgnore *
</IfModule>

RewriteEngine On

# ─────────── Canonical host: force https + non-www (production only) ───────────
RewriteCond %{HTTP_HOST} ^www\.dosacc\.com$ [NC]
RewriteRule ^ https://dosacc.com%{REQUEST_URI} [R=301,L]
RewriteCond %{HTTP_HOST} ^dosacc\.com$ [NC]
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://dosacc.com%{REQUEST_URI} [R=301,L]

# ─────────── Canonical paths: one URL per page ───────────
# /index.html (root or subdir) -> directory URL
RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html[?\s] [NC]
RewriteRule ^(.*/)?index\.html$ /%1 [R=301,L]
# /page.html -> /page (the clean-URL rewrite below serves the file again)
RewriteCond %{THE_REQUEST} \s/+([^\s?]+)\.html[?\s] [NC]
RewriteRule ^(.+)\.html$ /$1 [R=301,L]

# Clean contact URL: serve the homepage at /contact (the URL stays /contact in the bar);
# index.html scrolls to the contact section when loaded on this path.
# /contact/ redirects to /contact so the homepage's relative asset paths still resolve.
RewriteRule ^contact/$ /contact [R=301,L]
RewriteRule ^contact$ index.html [L]

# Clean URLs: serve /events as events.html, /leadership as leadership.html, etc.
# Only rewrites when the requested path isn't a real file/directory but a .html version exists.
# Uses DOCUMENT_ROOT+REQUEST_URI (not REQUEST_FILENAME, which collapses path-info:
# /events/nope would resolve to the real file /events and loop until a 500).
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
RewriteRule ^(.+)$ $1.html [L]

# ───────────────── Custom error page ─────────────────
ErrorDocument 404 /404.html

# ───────────────── Compression ─────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/javascript application/json image/svg+xml
</IfModule>

# ───────────────── Browser caching ─────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>
